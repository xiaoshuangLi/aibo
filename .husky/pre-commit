#!/usr/bin/env sh

# Run pre-commit checks
echo "🔍 Pre-commit checks started..."

# 1. Run test coverage check (must pass all tests)
echo "🧪 Running test coverage check..."
npm run test:coverage
if [ $? -ne 0 ]; then
    echo "❌ Test coverage generation failed! Please fix test failures before committing."
    exit 1
fi

# 2. Check coverage threshold (must be >= 85%)
echo "📊 Checking coverage threshold..."
node ./scripts/check-coverage-threshold.js
if [ $? -ne 0 ]; then
    echo "❌ Coverage threshold check failed! Coverage must be at least 85%."
    exit 1
fi

# 3. Run build check (only if tests pass and coverage is sufficient)
echo "📦 Running build check..."
./scripts/pre-commit-build.sh
if [ $? -ne 0 ]; then
    echo "❌ Build check failed! Please fix build errors before committing."
    exit 1
fi

echo "✅ All pre-commit checks passed! Ready to commit."
exit 0