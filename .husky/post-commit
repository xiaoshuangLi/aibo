#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Auto-push to remote after successful commit
echo "🚀 Auto-pushing to remote repository..."

# Get the current branch name
BRANCH=$(git branch --show-current)

if [ -z "$BRANCH" ]; then
    echo "⚠️  Could not determine current branch. Skipping auto-push."
    exit 0
fi

echo "📦 Pushing to origin/$BRANCH..."
git push origin "$BRANCH"

if [ $? -ne 0 ]; then
    echo "❌ Auto-push failed! Please push manually."
    exit 1
else
    echo "✅ Successfully pushed to origin/$BRANCH"
    exit 0
fi