# AI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional
MODEL_NAME=gpt-4o

# LangChain Configuration
RECURSION_LIMIT=1000
CHECKPOINTER_TYPE=memory  # or 'sqlite' or 'filesystem' to use file system checkpointing

# Memory Configuration
MEMORY_WINDOW_SIZE=5

# Output Configuration
VERBOSE_OUTPUT=false  # Enable verbose output for debugging

# Language Configuration
LANGUAGE=en  # Language for prompts and responses ('en' for English, 'zh' for Chinese, default: 'en')

# Tencent Cloud ASR and WSA Configuration
TENCENTCLOUD_APP_ID=your-app-id          # Required for voice input and web search
TENCENTCLOUD_SECRET_ID=your-secret-id    # Required for voice input and web search
TENCENTCLOUD_SECRET_KEY=your-secret-key  # Required for voice input and web search
TENCENTCLOUD_REGION=ap-guangzhou         # Optional, default: ap-guangzhou

# Composio Configuration
COMPOSIO_API_KEY=test-composio-api-key        # Required for Composio integration
COMPOSIO_EXTERNAL_USER_ID=test-external-user-id  # Required for Composio integration

# Advanced Subtask Configuration
MAX_CONCURRENT_SUBTASKS=5  # Maximum number of concurrent subtasks (1-50, default: 5)

# Special keyword configuration
SPECIAL_KEYWORD=干活  # Keyword that triggers special behavior in voice and terminal input