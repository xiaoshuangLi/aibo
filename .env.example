# Model Configuration
# AIBO_API_KEY     — unified API key for any provider (not required for Ollama)
# AIBO_BASE_URL    — unified base URL (required for Azure; defaults to http://localhost:11434 for Ollama)
# AIBO_MODEL_NAME  — model name (auto-detects provider from prefix; see AIBO_MODEL_PROVIDER for overrides)
# AIBO_MODEL_PROVIDER — explicit provider: openai | anthropic | google | mistral | groq | ollama | azure
#                       Required for groq / ollama / azure (cannot be detected from model name alone)
# AIBO_AZURE_API_VERSION — Azure OpenAI API version (only for azure provider, default: 2024-02-15-preview)
#
# Examples:
#   OpenAI  :  AIBO_API_KEY=sk-...          AIBO_MODEL_NAME=gpt-4o
#   Anthropic: AIBO_API_KEY=sk-ant-...      AIBO_MODEL_NAME=claude-3-5-sonnet-20241022
#   Google  :  AIBO_API_KEY=AIzaSy-...      AIBO_MODEL_NAME=gemini-2.0-flash
#   Mistral :  AIBO_API_KEY=...             AIBO_MODEL_NAME=mistral-large-latest
#   Groq    :  AIBO_API_KEY=gsk_...         AIBO_MODEL_NAME=llama-3.3-70b-versatile  AIBO_MODEL_PROVIDER=groq
#   Ollama  :  AIBO_BASE_URL=http://localhost:11434  AIBO_MODEL_NAME=llama3  AIBO_MODEL_PROVIDER=ollama
#   Azure   :  AIBO_API_KEY=...  AIBO_BASE_URL=https://<instance>.openai.azure.com  AIBO_MODEL_NAME=<deployment>  AIBO_MODEL_PROVIDER=azure
#   OpenAI-compatible (DeepSeek, Qwen, etc.):  AIBO_API_KEY=...  AIBO_BASE_URL=https://api.deepseek.com  AIBO_MODEL_NAME=deepseek-chat
AIBO_API_KEY=your-api-key
AIBO_BASE_URL=                              # Optional; custom endpoint for the provider
AIBO_MODEL_NAME=gpt-4o
AIBO_MODEL_PROVIDER=                        # Optional; auto-detected from model name when omitted
AIBO_AZURE_API_VERSION=2024-02-15-preview   # Only needed for Azure provider

# Backward-compatible aliases (still supported; AIBO_API_KEY / AIBO_BASE_URL take precedence)
# AIBO_OPENAI_API_KEY=your-openai-api-key
# AIBO_OPENAI_BASE_URL=https://api.openai.com/v1

# LangChain Configuration
AIBO_RECURSION_LIMIT=1000
AIBO_CHECKPOINTER_TYPE=memory  # or 'sqlite' or 'filesystem' to use file system checkpointing

# Memory Configuration
AIBO_MEMORY_WINDOW_SIZE=5

# Output Configuration
AIBO_VERBOSE_OUTPUT=false  # Enable verbose output for debugging

# Language Configuration
AIBO_LANGUAGE=en  # Language for prompts and responses ('en' for English, 'zh' for Chinese, default: 'en')

# Persona / Communication Style Configuration
AIBO_PERSONA=你的交流风格是魅魔人设：妩媚迷人、温柔体贴、善于撒娇。用甜蜜亲切的语气与用户互动，偶尔使用"主人"等称呼，举止优雅而富有魅力。在保持专业技术能力的同时，让每次对话都充满温情与趣味。  # Persona and communication style for the AI (default: 魅魔 persona)

# Tencent Cloud ASR and WSA Configuration
AIBO_TENCENTCLOUD_APP_ID=your-app-id          # Required for voice input and web search
AIBO_TENCENTCLOUD_SECRET_ID=your-secret-id    # Required for voice input and web search
AIBO_TENCENTCLOUD_SECRET_KEY=your-secret-key  # Required for voice input and web search
AIBO_TENCENTCLOUD_REGION=ap-guangzhou         # Optional, default: ap-guangzhou

# Composio Configuration
AIBO_COMPOSIO_API_KEY=test-composio-api-key        # Required for Composio integration
AIBO_COMPOSIO_EXTERNAL_USER_ID=test-external-user-id  # Required for Composio integration

# Lark (Feishu) Configuration
AIBO_LARK_APP_ID=your-lark-app-id              # Required for Lark/Feishu integration
AIBO_LARK_APP_SECRET=your-lark-app-secret      # Required for Lark/Feishu integration  
AIBO_LARK_RECEIVE_ID=your-lark-receive-id      # Optional, default receive ID for messages
AIBO_LARK_INTERACTIVE_TEMPLATE_ID=template-id  # Template ID for interactive Lark messages

# Advanced Subtask Configuration
AIBO_MAX_CONCURRENT_SUBTASKS=5  # Maximum number of concurrent subtasks (1-50, default: 5)

# Special keyword configuration
AIBO_SPECIAL_KEYWORD=干活  # Keyword that triggers special behavior in voice and terminal input

# Interaction Mode
# aibo starts in lark mode automatically when all four Lark vars above are configured.
# Override explicitly on the command line: aibo --interaction=console|lark