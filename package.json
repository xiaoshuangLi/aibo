{
  "name": "aibo",
  "version": "1.0.0",
  "description": "AI bot with DeepAgents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aibo": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "jest --verbose=false",
    "test:watch": "jest --verbose=false --watch",
    "test:coverage": "jest --verbose=false --coverage",
    "start": "node dist/main.js",
    "start:console": "AIBO_INTERACTION=console node dist/main.js",
    "start:lark": "AIBO_INTERACTION=lark node dist/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:console": "AIBO_INTERACTION=console ts-node -r tsconfig-paths/register src/main.ts",
    "dev:lark": "AIBO_INTERACTION=lark ts-node -r tsconfig-paths/register src/main.ts",
    "dev:lark-inspect": "AIBO_INTERACTION=lark node --inspect -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "prepare": "husky"
  },
  "author": "xiaoshuang",
  "license": "ISC",
  "dependencies": {
    "@composio/core": "^0.6.3",
    "@langchain/anthropic": "^1.3.15",
    "@langchain/core": "^1.1.19",
    "@langchain/google-genai": "^2.1.21",
    "@langchain/groq": "^1.1.3",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/mistralai": "^1.0.6",
    "@langchain/ollama": "^1.2.5",
    "@langchain/openai": "^1.2.5",
    "@langchain/tavily": "^1.2.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@types/turndown": "^5.0.6",
    "axios": "^1.13.5",
    "deepagents": "^1.7.2",
    "dotenv": "^17.2.4",
    "js-yaml": "^4.1.1",
    "langchain": "^1.2.18",
    "node-record-lpcm16": "^1.0.1",
    "puppeteer": "^24.37.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tencentcloud-sdk-nodejs": "^4.1.186",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.2",
    "@types/puppeteer": "^5.4.7",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3"
  }
}
