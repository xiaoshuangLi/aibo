{
  "name": "@boay/aibo",
  "version": "1.0.8",
  "description": "AI bot with DeepAgents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aibo": "bin/index.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "skills",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoshuangLi/aibo"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "test": "jest --verbose=false --forceExit",
    "test:watch": "jest --verbose=false --watch",
    "test:coverage": "jest --verbose=false --coverage --forceExit",
    "start": "node dist/main.js",
    "start:console": "AIBO_INTERACTION=console node dist/main.js",
    "start:lark": "AIBO_INTERACTION=lark node dist/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:console": "AIBO_INTERACTION=console ts-node -r tsconfig-paths/register src/main.ts",
    "dev:lark": "AIBO_INTERACTION=lark ts-node -r tsconfig-paths/register src/main.ts",
    "dev:lark-inspect": "AIBO_INTERACTION=lark node --inspect --experimental-network-inspection -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "prepare": "husky",
    "release": "npm publish --access public"
  },
  "author": "xiaoshuang",
  "license": "ISC",
  "dependencies": {
    "@composio/core": "^0.6.3",
    "@langchain/anthropic": "^1.3.15",
    "@langchain/core": "^1.1.19",
    "@langchain/google-genai": "^2.1.21",
    "@langchain/groq": "^1.1.3",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/mistralai": "^1.0.6",
    "@langchain/ollama": "^1.2.5",
    "@langchain/openai": "^1.2.5",
    "@langchain/tavily": "^1.2.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@types/turndown": "^5.0.6",
    "axios": "^1.13.5",
    "commander": "^9.5.0",
    "deepagents": "^1.8.3",
    "dotenv": "^17.2.4",
    "glob": "^11.1.0",
    "js-yaml": "^4.1.1",
    "langchain": "^1.2.18",
    "node-record-lpcm16": "^1.0.1",
    "playwright": "^1.55.1",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tencentcloud-sdk-nodejs": "^4.1.186",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "turndown": "^7.2.2",
    "typescript-language-server": "^5.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.2",
    "@types/screenshot-desktop": "^1.15.0",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
